# ── Provider selection ──────────────────────────────────────────────
# "openai" (default), "groq" (free tier), or "anthropic".
PROVIDER=openai

# ── OpenAI (default) ────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-key-here

# ── Groq (free tier) ────────────────────────────────────────────────
# Get a free key: https://console.groq.com/keys
# GROQ_API_KEY=gsk_your-groq-key-here

# ── Anthropic ───────────────────────────────────────────────────────
# ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Optional model overrides ────────────────────────────────────────
# Defaults: openai → gpt-4o ; groq → llama-3.3-70b-versatile ; anthropic → claude-sonnet-4-6
# Both strategies share one model so the comparison isolates prompt design.
# Override these to run a model-vs-model comparison instead.
# MODEL_A=gpt-4o
# MODEL_B=gpt-4o
# JUDGE_MODEL=gpt-4o
